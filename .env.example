# ==============================================================================
# CONFIGURACIÓN DE BASE DE DATOS MONGODB
# ==============================================================================
# En DESARROLLO LOCAL con Docker use: mongodb://mongodb:27017
# En PRODUCCIÓN: Cambie por la IP o dominio del servidor de MongoDB del cliente
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=pdf_manager

# Configuración de la base de datos (Desarrollo)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme

# Límite de tamaño de archivos PDF permitidos por la API (en MB)
MAX_FILE_SIZE_MB=20

# ==============================================================================
# CONFIGURACIÓN DEL CLIENTE DE CONSOLA (CLI)
# ==============================================================================
# IMPORTANTE: Esta variable NO la consume el servidor FastAPI, la utiliza el CLI.
# Debe apuntar a la URL pública o privada donde el servidor FastAPI sea accesible.
# En desarrollo: http://localhost:8000
# En producción: Cambiar por el dominio/IP del despliegue (ej: http://api.tuservicio.com)
API_BASE_URL=http://localhost:8000